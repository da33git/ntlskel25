 {
 	
    "extends": ["config:recommended", "mergeConfidence:all-badges"],
    "rangeStrategy": "bump",
    "packageRules": [
    {
    "description": "Svelte ecosystem (high risk)",
    "groupName": "svelte ecosystem",
    "automerge": false,
    "dependencyDashboardApproval": true,
    "matchPackageNames": [
    "/^svelte/",
    "/^@sveltejs//"
    ]
    },
     {
     "description": "Astro ecosystem (high risk)",
         "matchPackageNames": ["astro", "@astrojs/*"],
         "groupName": "astro framework updates",
         "automerge": false,
         "dependencyDashboardApproval": true
       },
    {
    "description": "Vite ecosystem",
    "groupName": "vite ecosystem",
    "matchPackageNames": [
    "/^vite/",
    "/^@vitejs//"
    ]
    },
    {
    "description": "Linting tools",
    "groupName": "linting",
    "automerge": false,
    "matchPackageNames": [
    "/^eslint/",
    "/^prettier/"
    ]
    },
    {
    "description": "Testing tools",
    "groupName": "testing",
    "matchPackageNames": [
    "/^vitest/",
    "/^jest/",
    "/^@testing-library/"
    ]
    },
    {
    "description": "Minor safe updates",
    "matchUpdateTypes": ["minor"],
    "matchCurrentVersion": "!/^0/",
    "automerge": false,
    "matchPackageNames": [
    "!/astro/",
    "!/@astrojs/*/",
    "!/^svelte/",
    "!/^@sveltejs//",
    "!/^vite/",
    "!/^@vitejs//"
    ]
    },
    {
    "description": "Patch safe updates",
    "matchUpdateTypes": ["patch"],
    "matchCurrentVersion": "!/^0/",
    "automerge": true,
    "matchPackageNames": [
    "!/astro/",
    "!/@astrojs/*/",
    "!/^svelte/",
    "!/^@sveltejs//",
    "!/^vite/",
    "!/^@vitejs//"
    ]
    },
        {
    "description": "Minor/patch safe updates",
    "matchUpdateTypes": ["minor", "patch"],
    "automerge": false,
          "matchPackageNames": [
                "!/astro/",
                "!/@astrojs/*/",
                "!/^svelte/",
                "!/^@sveltejs//",
                "!/^vite/",
                "!/^@vitejs//"
            ]
    },

    {
    "description": "Major updates require approval",
    "matchUpdateTypes": ["major"],
    "automerge": false,
    "dependencyDashboardApproval": true
    }
    ]
    }
